# Copy to .env and adjust. The defaults work for a local GPU run.

# --- Backend ---
# Set to 1 to run WITHOUT a GPU/model (serves deterministic fake boxes).
# Useful for frontend dev, CI, and machines with no NVIDIA GPU.
LA_MOCK=0

# HuggingFace model id or local path.
LA_MODEL_PATH=nvidia/LocateAnything-3B

# Default generation mode: fast | hybrid | slow
LA_DEFAULT_MODE=hybrid

# Which GPU to load the model on at startup (index from `nvidia-smi`).
# Can also be changed at runtime in the UI under System -> gpu.
LA_DEVICE=0

# Where the backend stores the SQLite db + uploaded/annotated images (inside container).
LA_DATA_DIR=/data

# HuggingFace cache dir (mounted as a volume so the ~6GB model downloads once).
HF_HOME=/hf_cache

# Optional: needed only if the model repo is gated on HuggingFace.
# HF_TOKEN=

# --- Ports (host side) ---
FRONTEND_PORT=8080
# Only used with the expose-backend override (the backend isn't published by default).
BACKEND_PORT=8000

# Optional: pin a published image version for the prebuilt (GHCR) compose file.
# LA_VERSION=v0.1.0
